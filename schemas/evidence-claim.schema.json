{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliance.aguilar-pelaez.co.uk/schemas/evidence-claim.schema.json",
  "title": "OpenCompliance Evidence Claim",
  "type": "object",
  "required": [
    "claimId",
    "claimType",
    "collectedAt",
    "sourceSystem",
    "actor",
    "controlMappings",
    "payload"
  ],
  "properties": {
    "claimId": {
      "type": "string",
      "minLength": 1
    },
    "claimType": {
      "type": "string",
      "minLength": 1
    },
    "collectedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceSystem": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "actorId",
        "actorType"
      ],
      "properties": {
        "actorId": {
          "type": "string",
          "minLength": 1
        },
        "actorType": {
          "type": "string",
          "enum": [
            "system",
            "human"
          ]
        }
      },
      "additionalProperties": false
    },
    "controlMappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "framework",
          "family"
        ],
        "properties": {
          "framework": {
            "type": "string",
            "minLength": 1
          },
          "family": {
            "type": "string",
            "minLength": 1
          },
          "controlId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "scope": {
      "type": "object",
      "properties": {
        "environment": {
          "type": "string"
        },
        "assetGroup": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "payload": {
      "type": "object"
    },
    "freshness": {
      "type": "object",
      "properties": {
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "signer": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
